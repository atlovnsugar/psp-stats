4],[397,0],[368,0],[398,0],[403,0],[404,0],[408,0],[129,0],[272,0],[417,0],[181,0],[185,0]],"tisk_info":{"tisk_id":19,"obdobi":3,"nazev":"Návrh novely zákona ČNR č. 367/1990 Sb. o obcích","konecny_stav":"Zamítnuto v 1. čtení","temata":["Správa obcí a měst","Správa státní","hlavní město","místní orgány státní správy","obec","Praha","rozhodovací pravomoc","územní samospráva","zástupce místního a regionálního zastupitelského orgánu"],"historie":["Skupina poslanců předložila sněmovně návrh zákona 27. 7. 1998. Zástupce navrhovatele: Frank Václav a další.","Návrh zákona rozeslán poslancům jako tisk 19/0 dne 30. 7. 1998.","Návrh zaslán vládě k vyjádření stanoviska 29. 7. 1998. Vláda zaslala stanovisko 27. 8. 1998. Stanovisko vlády rozesláno poslancům 27. 8. 1998 jako tisk 19/1 ( nesouhlas ).","Předseda sněmovny projednání návrhu zákona doporučil 4. 9. 1998. Určil zpravodaje: Mgr. Radko Martínek a navrhl přikázat k projednání výborům: Výbor pro veřejnou správu, regionální rozvoj a životní prostředí","1. Čtení proběhlo 15. , 16. 10. 1998 na 5. schůzi. Návrh zákona zamítnut (hlasování č. 62 , usnesení č. 58 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[58]}}