[395,0],[397,0],[368,4],[398,0],[403,0],[404,0],[408,0],[129,0],[272,4],[417,0],[181,4],[185,0]],"tisk_info":{"tisk_id":131,"obdobi":3,"nazev":"Návrh novely Zákoníku práce","konecny_stav":"Zamítnuto v 1. čtení","temata":["Zákoník práce","Zaměstnanost","politika zaměstnanosti","zákoník práce","zákonná pracovní doba","zkrácení pracovní doby"],"historie":["Skupina poslanců ( Jaroslav Štrait , Václav Exner , Jaromír Kohlíček , Pavel Kováčik ) předložila sněmovně návrh zákona 15. 2. 1999. Zástupce navrhovatele: Štrait Jaroslav a další.","Návrh zákona rozeslán poslancům jako tisk 131/0 dne 17. 2. 1999.","Návrh zaslán vládě k vyjádření stanoviska 17. 2. 1999. Vláda zaslala stanovisko 18. 3. 1999. Stanovisko vlády rozesláno poslancům 18. 3. 1999 jako tisk 131/1 ( nesouhlas ).","Organizační výbor projednání návrhu zákona doporučil 24. 3. 1999 (usnesení č. 100 ). Určil zpravodaje: Ing. Alena Páralová a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví","1. Čtení proběhlo 1. 6. 1999 na 13. schůzi. Návrh zákona zamítnut (usnesení č. 290 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[290]}}