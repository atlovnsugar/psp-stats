25,0],[317,0],[364,1],[380,1],[381,1],[79,4],[389,1],[91,1],[395,4],[397,1],[368,4],[398,1],[403,4],[404,1],[408,1],[129,1],[272,4],[417,4],[181,1],[185,1],[394,4]],"tisk_info":{"tisk_id":280,"obdobi":3,"nazev":"Návrh novely zákona o majetku v družstvech","konecny_stav":"Zamítnuto v 2. čtení","temata":["Družstva","Vztahy vlastnické","převod vlastnictví","vlastnický podíl","zemědělské družstvo"],"historie":["Skupina poslanců ( Vlastimil Tlustý , Pavel Pešek ) předložila sněmovně návrh zákona 23. 6. 1999. Zástupce navrhovatele: Tlustý Vlastimil.","Návrh zákona rozeslán poslancům jako tisk 280/0 dne 25. 6. 1999.","Návrh zaslán vládě k vyjádření stanoviska 28. 6. 1999. Vláda zaslala stanovisko 27. 7. 1999. Stanovisko vlády rozesláno poslancům 27. 7. 1999 jako tisk 280/1 ( nesouhlas ).","Předseda sněmovny projednání návrhu zákona doporučil 4. 8. 1999. Určil zpravodaje: Ing. Jaroslav Palas a navrhl přikázat k projednání výborům: Zemědělský výbor (rozhodnutí č. 26 )","1. Čtení proběhlo 7. 12. 1999 na 19. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 652 ).","Zemědělský výbor projednal návrh zákona a vydal 19. 1. 2000 usnesení doručené poslancům jako tisk 280/2 .","2. Čtení Návrh zákona v obecné rozpravě 22. 2. 2000 na 22. schůzi zamítnut (hlasování č. 38 , usnesení č. 792 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[652,792]}}