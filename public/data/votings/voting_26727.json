,[364,1],[380,4],[381,1],[79,1],[389,4],[91,2],[395,4],[397,4],[368,1],[398,2],[403,4],[404,1],[5241,1],[129,4],[272,4],[417,1],[185,1],[394,4],[408,4]],"tisk_info":{"tisk_id":1125,"obdobi":3,"nazev":"Návrh zák. na záruky ČR na rekonstrukci FN v Motole","konecny_stav":"Vzat zpět v 1. čtení","temata":["Bankovnictví","Zdravotnictví","nemocniční zařízení","ochrana investic","úvěr","záruka úvěru"],"historie":["Skupina poslanců ( Petra Buzková , Vlastimil Tlustý , Václav Krása , Zdeněk Škromach ) předložila sněmovně návrh zákona 24. 10. 2001. Zástupce navrhovatele: Buzková Petra a další.","Návrh zákona rozeslán poslancům jako tisk 1125/0 dne 26. 10. 2001.","Návrh zaslán vládě k vyjádření stanoviska 26. 10. 2001. Vláda zaslala stanovisko 15. 11. 2001. Stanovisko vlády rozesláno poslancům 16. 11. 2001 jako tisk 1125/1 ( připomínky ).","Organizační výbor projednání návrhu zákona doporučil 15. 11. 2001 (usnesení č. 476 ). Určil zpravodaje: MUDr. Milan Cabrnoch a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví","1. Čtení bylo zahájeno 12. 12. 2001 na 43. schůzi, projednávání bylo přerušeno (hlasování č. 298 , usnesení č. 1942 ). 1. Čtení Návrh zákona vzat zpět 12. 3. 2002."],"souvisejici_tisky":[],"souvisejici_usneseni":[1942]}}