[392,4],[340,4],[5262,0],[416,3],[5315,0],[301,0],[420,0],[302,0],[5324,0],[193,0],[5309,2],[5323,4],[5325,0],[5224,0],[100,2],[389,0],[398,4],[403,4],[5305,0],[5287,4],[417,0]],"tisk_info":{"tisk_id":122,"obdobi":4,"nazev":"Vládní návrh zákona o sociální potřebnosti","konecny_stav":"Neschváleno","temata":["Potřebnost sociální","nízká mzda","osobní vlastnictví","sociální dávky","sociální péče","sociální pomoc","uspokojení z práce","vlastní spotřeba","životní minimum"],"historie":["Vláda předložila sněmovně návrh zákona 12. 11. 2002. Zástupce navrhovatele: Škromach Zdeněk.","Návrh zákona rozeslán poslancům jako tisk 122/0 dne 13. 11. 2002. Předseda sněmovny projednání zákona doporučil 15. 11. 2002. Určil zpravodaje: RSDr. Antonín Zralý a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví (rozhodnutí č. 14 )","Čtení proběhlo 26. 11. 2002 na 8. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 164 ).","Výbor pro sociální politiku a zdravotnictví projednal návrh zákona a vydal 11. 2. 2003 záznam z jednání doručený poslancům jako tisk 122/Z .","2. Čtení Návrh zákona prošel obecnou rozpravou 19. 2. 2003 na 10. schůzi. Návrh zákona prošel podrobnou rozpravou 19. 2. 2003 na 10. schůzi. Podané pozměňovací návrhy zpracovány jako tisk 122/1 , který byl rozeslán 25. 2. 2003 v 17:00.","3. Čtení proběhlo 5. 3. 2003 na 10. schůzi. Návrh zákona nebyl schválen (hlasování č. 387 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[164]}}