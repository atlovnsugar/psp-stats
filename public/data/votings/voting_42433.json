[317,0],[5304,0],[295,3],[333,2],[5291,1],[297,1],[5314,1],[54,1],[377,2],[63,1],[64,4],[390,1],[392,4],[340,4],[5262,1],[143,3],[416,3],[5315,2],[301,1],[420,4],[302,2],[5324,4],[5309,1],[5325,2],[5224,0],[381,4],[5286,0],[389,4],[403,4],[5305,4],[5287,2],[417,4],[5357,0],[5365,4]],"tisk_info":{"tisk_id":932,"obdobi":4,"nazev":"N. z. o ochraně před škodami působenými tabákovými výrobky","konecny_stav":"Vráceno","temata":["Ochrana zdraví","Tabák, tabákové výrobky","kouření","ochrana dítěte","povolení k prodeji","prevence nemocí","tabák","zdravotní politika","zdravotní riziko"],"historie":["Skupina poslanců předložila sněmovně návrh zákona 23. 3. 2005. Zástupce navrhovatele: Janeček Josef a další.","Návrh zákona rozeslán poslancům jako tisk 932/0 dne 29. 3. 2005.","Návrh zaslán vládě k vyjádření stanoviska 30. 3. 2005. Vláda zaslala stanovisko 28. 4. 2005. Stanovisko vlády rozesláno poslancům 29. 4. 2005 jako tisk 932/1 ( nesouhlas ).","Organizační výbor projednání návrhu zákona doporučil 11. 5. 2005 (usnesení č. 442 ). Určil zpravodaje: Ing. Lucie Talmanová a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví","1. Čtení bylo zahájeno 22. 6. 2005 na 45. schůzi, projednávání bylo odročeno (hlasování č. 263 , usnesení č. 1743 ). Projednávání pokračovalo 7. 2. 2006 na 53. schůzi. Návrh zákona vrácen (hlasování č. 376 , usnesení č. 2171 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[1743,2171]}}