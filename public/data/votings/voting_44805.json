,[305,0],[4778,0],[5461,0],[366,0],[5321,4],[5313,0],[309,4],[5274,0],[5290,0],[5328,0],[5308,0],[5322,0],[5502,0],[5282,2],[5506,0],[4527,0],[5268,0],[295,4],[5449,2],[5291,2],[5314,2],[377,2],[64,4],[390,0],[340,4],[143,4],[416,4],[5326,0],[301,2],[420,4],[441,3],[5466,2],[5467,2],[5480,2],[5494,2],[5523,2],[230,2],[5491,3]],"tisk_info":{"tisk_id":119,"obdobi":5,"nazev":"Vl.n.z. o integrovaném registru znečišťování život.prostředí - EU","konecny_stav":"Vzat zpět v 2. čtení","temata":["Ekologie","Evropská unie /EU/","nebezpečná látka","opatření na kontrolu znečištění","prevence environmentálních rizik","prevence znečištění","sledování životního prostředí","veřejné prohlášení"],"historie":["Vláda předložila sněmovně návrh zákona 18. 12. 2006. Zástupce navrhovatele: ministr živ. prostředí.","Návrh zákona rozeslán poslancům jako tisk 119/0 dne 3. 1. 2007.","Organizační výbor projednání návrhu zákona doporučil 11. 1. 2007 (usnesení č. 61 ). Určil zpravodaje: Mgr. Tomáš Úlehla a navrhl přikázat k projednání výborům: Výbor pro životní prostředí","Čtení proběhlo 30. 1. 2007 na 11. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 175 ). Lhůta k projednání výbory byla určena na 30 dní .","Výbor pro životní prostředí projednal návrh zákona a vydal 28. 2. 2007 usnesení doručené poslancům jako tisk 119/1 (pozměňovací návrhy) . Hospodářský výbor projednal návrh zákona a vydal 2. 3. 2007 usnesení doručené poslancům jako tisk 119/2 (pozměňovací návrhy) .","2. Čtení Sněmovní tisk byl 15. 3. 2007 vyřazen z programu 13. schůze. Návrh zákona 16. 4. 2007 vzat zpět ."],"souvisejici_tisky":[],"souvisejici_usneseni":[175]}}