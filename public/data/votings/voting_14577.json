,[395,4],[397,0],[368,0],[398,4],[403,4],[404,4],[408,0],[129,0],[272,4],[417,4],[181,4],[185,0]],"tisk_info":{"tisk_id":110,"obdobi":3,"nazev":"Vládní návrh novely zákona o léčivech a o péči o zdraví lidu","konecny_stav":"Zamítnuto v 3. čtení","temata":["Léčiva","farmaceutická legislativa","farmaceutický výrobek","farmakologie","kontrola léčiv","léčba","seznam léčiv","veterinární léčivý přípravek"],"historie":["Vláda předložila sněmovně návrh zákona 21. 1. 1999. Zástupce navrhovatele: David Ivan.","Návrh zákona rozeslán poslancům jako tisk 110/0 dne 21. 1. 1999.","Organizační výbor projednání návrhu zákona doporučil 21. 1. 1999 (usnesení č. 71 ). Určil zpravodaje: MUDr. Milan Cabrnoch a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví","Čtení proběhlo 4. 2. 1999 na 9. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 110 ).","Výbor pro sociální politiku a zdravotnictví projednal návrh zákona a vydal 24. 6. 1999 usnesení doručené poslancům jako tisk 110/1 .","2. Čtení Návrh zákona prošel obecnou rozpravou 29. 6. 1999 na 15. schůzi. Návrh zákona prošel podrobnou rozpravou 29. 6. 1999 na 15. schůzi. Podané pozměňovací návrhy zpracovány jako tisk 110/2 , který byl rozeslán 1. 7. 1999 v 17:00.","3. Čtení proběhlo 9. 7. 1999 na 15. schůzi. Návrh zákona zamítnut (hlasování č. 371 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[110]}}