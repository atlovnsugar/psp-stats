2,0],[425,0],[317,0],[364,1],[380,4],[381,4],[79,1],[389,1],[91,1],[395,1],[397,4],[368,1],[398,1],[403,1],[404,1],[408,1],[129,1],[272,4],[417,1],[181,1],[185,4],[394,4]],"tisk_info":{"tisk_id":401,"obdobi":3,"nazev":"Novela trestního zákona","konecny_stav":"Zamítnuto v 2. čtení","temata":["Extremismus","Zákon trestní","antidiskriminační politika","etnická diskriminace","náboženská diskriminace","právo na spravedlnost","rasová diskriminace","trestní právo","xenofobie"],"historie":["Skupina poslanců ( Jiří Payne , Marek Benda , Eva Dundáčková , Petr Mareš , Miloš Titz ) předložila sněmovně návrh zákona 26. 10. 1999. Zástupce navrhovatele: Payne Jiří.","Návrh zákona rozeslán poslancům jako tisk 401/0 dne 1. 11. 1999.","Návrh zaslán vládě k vyjádření stanoviska 1. 11. 1999. Vláda zaslala stanovisko 30. 11. 1999. Stanovisko vlády rozesláno poslancům 1. 12. 1999 jako tisk 401/1 ( nesouhlas ).","Organizační výbor projednání návrhu zákona doporučil 1. 12. 1999 (usnesení č. 202 ). Určil zpravodaje: JUDr. Pavel Němec a navrhl přikázat k projednání výborům: Ústavně právní výbor","1. Čtení proběhlo 25. 1. 2000 na 21. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 727 ).","Ústavně právní výbor projednal návrh zákona a vydal 28. 3. 2000 usnesení doručené poslancům jako tisk 401/2 .","2. Čtení Návrh zákona v obecné rozpravě 5. 4. 2000 na 24. schůzi zamítnut (hlasování č. 51 , usnesení č. 914 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[727,914]}}