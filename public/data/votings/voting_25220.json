,[425,1],[317,0],[364,0],[380,0],[381,0],[79,0],[389,0],[91,0],[395,4],[397,0],[368,0],[398,0],[403,0],[404,0],[408,0],[129,0],[272,0],[417,0],[181,4],[185,0],[394,4]],"tisk_info":{"tisk_id":776,"obdobi":3,"nazev":"Vlád. n. zák. o Sociální pojišťovně","konecny_stav":"Zamítnuto v 2. čtení","temata":["Pojištění","Pojišťovny","důchodový plán","politika zaměstnanosti","sociální dávky","sociální zabezpečení","zdravotní pojištění"],"historie":["Vláda předložila sněmovně návrh zákona 13. 11. 2000. Zástupce navrhovatele: Špidla Vladimír.","Návrh zákona rozeslán poslancům jako tisk 776/0 dne 14. 11. 2000.","Organizační výbor projednání návrhu zákona doporučil 16. 11. 2000 (usnesení č. 335 ). Určil zpravodaje: Ing. Ludmila Müllerová a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví","Čtení proběhlo 16. 5. 2001 na 36. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 1571 ).","Rozpočtový výbor projednal návrh zákona a vydal 8. 10. 2001 usnesení doručené poslancům jako tisk 776/1 . Rozpočtový výbor vydal 9. 10. 2001 oponentní zprávu jako tisk 776/2 . Výbor pro sociální politiku a zdravotnictví projednal návrh zákona a vydal 12. 10. 2001 usnesení doručené poslancům jako tisk 776/3 .","2. Čtení Návrh zákona v obecné rozpravě 31. 10. 2001 zamítnut na 39. schůzi (hlasování č. 466 , usnesení č. 1822 )."],"souvisejici_tisky":[776,777],"souvisejici_usneseni":[1571,1822]}}