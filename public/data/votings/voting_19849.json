317,1],[364,0],[380,4],[381,0],[79,0],[389,0],[91,0],[395,4],[397,0],[368,0],[398,0],[403,4],[404,0],[408,0],[129,0],[272,0],[417,0],[181,4],[185,0],[394,4]],"tisk_info":{"tisk_id":370,"obdobi":3,"nazev":"Zákon o státním zastupitelství","konecny_stav":"Zamítnuto v 2. čtení","temata":["Soudnictví","jmenování pracovníků","místní příslušnost","právní postavení","soudce a státní zástupce","soudní řízení","státní zástupce"],"historie":["Vláda předložila sněmovně návrh zákona 27. 9. 1999. Zástupce navrhovatele: Motejl Otakar.","Návrh zákona rozeslán poslancům jako tisk 370/0 dne 28. 9. 1999.","Organizační výbor projednání návrhu zákona doporučil 30. 9. 1999 (usnesení č. 173 ). Určil zpravodaje: JUDr. Eva Dundáčková a navrhl přikázat k projednání výborům: Ústavně právní výbor","1. Čtení proběhlo 3. 11. 1999 na 17. schůzi. Projednávání návrhu bylo přerušeno (usnesení č. 549 ). Čtení proběhlo 20. 1. 2000 na 21. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 707 ).","Ústavně právní výbor projednal návrh zákona a vydal 14. 9. 2000 usnesení doručené poslancům jako tisk 370/1 .","2. Čtení Návrh zákona v obecné rozpravě 15. 9. 2000 zamítnut na 27. schůzi (hlasování č. 84 , usnesení č. 1182 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[549,707,1182]}}