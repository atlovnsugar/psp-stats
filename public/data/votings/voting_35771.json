,[333,0],[5291,0],[297,3],[5314,0],[54,0],[377,4],[63,0],[64,0],[390,4],[392,4],[340,0],[5262,0],[143,0],[416,3],[5315,0],[301,4],[420,0],[302,0],[5324,0],[5309,0],[5323,1],[5325,1],[5224,2],[389,4],[403,3],[5305,4],[5287,4],[417,3],[5357,4],[5365,2],[5286,4]],"tisk_info":{"tisk_id":417,"obdobi":4,"nazev":"V.n.z. o zdrav.pojištění dětí cizinců","konecny_stav":"Zamítnuto v 2. čtení","temata":["Cizinci","Pojištění","cizí státní občan","dítě migrující rodiny","povolení k pobytu","zdravotní pojištění"],"historie":["Vláda předložila sněmovně návrh zákona 28. 7. 2003. Zástupce navrhovatele: Kubinyi Jozef.","Návrh zákona rozeslán poslancům jako tisk 417/0 dne 29. 7. 2003. Předseda sněmovny projednání zákona doporučil 21. 8. 2003. Určil zpravodaje: MUDr. Jiří Maštálka a navrhl přikázat k projednání výborům: Výbor pro sociální politiku a zdravotnictví (rozhodnutí č. 27 )","Čtení proběhlo 29. 10. 2003 na 22. schůzi. Návrh zákona přikázán k projednání výborům (usnesení č. 707 ).","Výbor pro sociální politiku a zdravotnictví projednal návrh zákona a vydal 28. 1. 2004 usnesení doručené poslancům jako tisk 417/1 (přerušuje projednávání) . Výbor pro sociální politiku a zdravotnictví projednal návrh zákona a vydal 8. 3. 2004 usnesení doručené poslancům jako tisk 417/2 (přerušuje projednávání) . Výbor pro sociální politiku a zdravotnictví projednal návrh zákona a vydal 19. 4. 2004 usnesení doručené poslancům jako tisk 417/3 (doporučuje zamítnout) .","2. Čtení Návrh zákona v obecné rozpravě 4. 5. 2004 zamítnut na 31. schůzi (hlasování č. 29 , usnesení č. 1102 )."],"souvisejici_tisky":[],"souvisejici_usneseni":[707,1102]}}